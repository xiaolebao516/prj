// main.c
#include "app_main.h"      // 引入店长
#include "app_monitor.h"   // 引入数据监控大管家

int main() {
    // 1. 系统装配
    Hardware_Init();
    Network_Init();
    UI_Init();
    App_Monitor_Init();

    // 2. 核心调度
    while(1) {
        Network_Task();     // 处理网络接收
        LVGL_Task();        // 刷新屏幕帧
        App_Monitor_Task(); // 处理ADC数据与UI更新
    }

    return 0;
}
